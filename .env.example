# ────────────────────────────────────────────────────────────────────────
# Red Cardinal Aviation — environment variables
# Copy this file to .env.local for local development, and configure
# the same keys in Vercel → Project Settings → Environment Variables
# (Production + Preview). Never commit real values to git.
# ────────────────────────────────────────────────────────────────────────

# SMTP credentials (used by lib/email.ts to send contact + discovery form
# submissions). Works with any standard SMTP provider — Gmail / Google
# Workspace, Microsoft 365, SendGrid, Mailgun, Postmark, Resend SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where form submissions get delivered. Defaults to info@redcardinalaviation.com
# if unset. Override to route to a different inbox.
EMAIL_TO=info@redcardinalaviation.com

# The visible "From" address on outbound mail. Many providers require this
# to match SMTP_USER or a verified domain sender. Defaults to SMTP_USER if unset.
EMAIL_FROM=info@redcardinalaviation.com
